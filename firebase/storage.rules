rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Association images (logo, icon) — public read, authenticated write
    match /associations/{associationId}/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // DNI images — only the owner can write, managers of the association can read
    match /memberships/{associationId}/{userId}/dni/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Signature images — only the owner can write, managers can read
    match /memberships/{associationId}/{userId}/signature/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Event images — authenticated write, public read
    match /events/{associationId}/{eventId}/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
